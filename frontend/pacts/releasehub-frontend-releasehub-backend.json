{
  "consumer": {
    "name": "releasehub-frontend"
  },
  "interactions": [
    {
      "description": "a login request with valid credentials",
      "providerStates": [
        {
          "name": "admin user exists"
        }
      ],
      "request": {
        "body": {
          "password": "admin",
          "username": "admin"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/v1/auth/login"
      },
      "response": {
        "body": {
          "code": "0",
          "data": {
            "token": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbiJ9.signature"
          },
          "message": "success"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.code": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a login request with wrong password",
      "providerStates": [
        {
          "name": "admin user exists"
        }
      ],
      "request": {
        "body": {
          "password": "wrong",
          "username": "admin"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/v1/auth/login"
      },
      "response": {
        "body": {
          "code": "AUTH_FAILED",
          "data": null,
          "message": "auth failed"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.code": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "releasehub-backend"
  }
}